# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Supabase (Dashboard SPA — safe, anon key is RLS-restricted) ──
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# ── Supabase Edge Function secrets ────────────────────────────────
# Set these via the Supabase CLI (never put secrets in .env):
#   supabase secrets set OPENAI_API_KEY=sk-...
#   supabase secrets set SESSION_SECRET=$(openssl rand -hex 32)
#   supabase secrets set RESEND_API_KEY=re_...
#   supabase secrets set ESCALATION_FROM_EMAIL=noreply@yourdomain.com
#   supabase secrets set WHATSAPP_TOKEN=<meta-token>
#   supabase secrets set WHATSAPP_PHONE_ID=<meta-phone-number-id>

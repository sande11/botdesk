# Copy this file to .env and fill in your values
# Never commit .env to version control

# Your LLM provider API key (Claude or OpenAI)
VITE_AI_API_KEY=

# Your backend API base URL
VITE_API_BASE_URL=http://localhost:4000

# Widget public API key (set this to the key you generate in the dashboard)
VITE_WIDGET_API_KEY=

# Supabase (for vector DB + auth)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=

# Email (Resend)
RESEND_API_KEY=
ESCALATION_FROM_EMAIL=noreply@yourdomain.com
